{
  "name": "Product",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do produto"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o detalhada do produto"
    },
    "price": {
      "type": "number",
      "description": "Pre\u00e7o em reais"
    },
    "original_price": {
      "type": "number",
      "description": "Pre\u00e7o original (para mostrar desconto)"
    },
    "category": {
      "type": "string",
      "enum": [
        "roupas",
        "acess\u00f3rios",
        "cal\u00e7ados",
        "beleza",
        "casa",
        "eletr\u00f4nicos",
        "outros"
      ],
      "description": "Categoria do produto"
    },
    "image_url": {
      "type": "string",
      "description": "URL da imagem principal"
    },
    "images": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs das imagens adicionais"
    },
    "stock": {
      "type": "number",
      "description": "Quantidade em estoque"
    },
    "featured": {
      "type": "boolean",
      "description": "Produto em destaque na home"
    },
    "badge": {
      "type": "string",
      "description": "Badge especial (ex: Novo, Promo\u00e7\u00e3o)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags do produto"
    }
  },
  "required": [
    "name",
    "price"
  ]
}
